<Window x:Class="Obc.Bs.Windows.UI.SKI.JobRegistration.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodel="clr-namespace:Obc.Bs.Windows.UI.SKI.JobRegistration.ViewModel"
        mc:Ignorable="d"
        Title="職種登録" Height="450" Width="800"
        Background="#E6EBEF">
    <Window.Resources>
        <!-- ファンクションキーのスタイル -->
        <Style x:Key="FKeyStyle" TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F8F8F8" Offset="0.0"/>
                        <GradientStop Color="#E0E0E0" Offset="0.5"/>
                        <GradientStop Color="#D0D0D0" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="Gray"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGridヘッダーのスタイル -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#808080"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="Black"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <viewmodel:MainViewModel/>
    </Window.DataContext>
    
    <Window.InputBindings>
        <KeyBinding Key="F7" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="F10" Command="{Binding CancelCommand}" />
        <KeyBinding Key="F12" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 入力エリア (ラベル付き) -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <!-- コード -->
            <StackPanel Margin="0,0,10,0">
                <Border Background="#808080" BorderBrush="Black" BorderThickness="1,1,1,0" Padding="5,2">
                    <TextBlock Text="コード" Foreground="White" FontWeight="Bold" Width="80"/>
                </Border>
                <Border BorderBrush="Black" BorderThickness="1">
                    <TextBox Text="{Binding InputCode, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Yellow" Width="92" Height="25" VerticalContentAlignment="Center" BorderThickness="0"/>
                </Border>
            </StackPanel>

            <!-- 名称 -->
            <StackPanel Margin="0,0,10,0">
                <Border Background="#808080" BorderBrush="Black" BorderThickness="1,1,1,0" Padding="5,2">
                    <TextBlock Text="名称" Foreground="White" FontWeight="Bold" Width="300"/>
                </Border>
                <Border BorderBrush="Black" BorderThickness="1">
                    <TextBox Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" 
                             Width="312" Height="25" VerticalContentAlignment="Center" BorderThickness="0"/>
                </Border>
            </StackPanel>

            <!-- 略称 -->
            <StackPanel>
                <Border Background="#808080" BorderBrush="Black" BorderThickness="1,1,1,0" Padding="5,2">
                    <TextBlock Text="略称" Foreground="White" FontWeight="Bold" Width="120"/>
                </Border>
                <Border BorderBrush="Black" BorderThickness="1">
                    <TextBox Text="{Binding InputAbbreviation, UpdateSourceTrigger=PropertyChanged}" 
                             Width="132" Height="25" VerticalContentAlignment="Center" BorderThickness="0"/>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- 一覧エリア -->
        <DataGrid Grid.Row="1" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                  SelectionMode="Single" SelectionUnit="FullRow"
                  GridLinesVisibility="All" Background="White" RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="コード" Binding="{Binding C_JobCode}" Width="100"/>
                <DataGridTextColumn Header="名称" Binding="{Binding C_JobName}" Width="*"/>
                <DataGridTextColumn Header="略称" Binding="{Binding C_JobAbbreviationName}" Width="150"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- フッターエリア (ファンクションキー) -->
        <UniformGrid Grid.Row="2" Columns="12" Margin="0,15,0,0">
            <Button Content="F1" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F2" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F3" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F4" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F5" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F6" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Command="{Binding DeleteCommand}" Style="{StaticResource FKeyStyle}">
                <StackPanel>
                    <TextBlock Text="F7" HorizontalAlignment="Center"/>
                    <TextBlock Text="削除" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="F8" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Content="F9" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Command="{Binding CancelCommand}" Style="{StaticResource FKeyStyle}">
                <StackPanel>
                    <TextBlock Text="F10" HorizontalAlignment="Center"/>
                    <TextBlock Text="中止" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Content="F11" IsEnabled="False" Style="{StaticResource FKeyStyle}"/>
            <Button Command="{Binding SaveCommand}" Style="{StaticResource FKeyStyle}">
                <StackPanel>
                    <TextBlock Text="F12" HorizontalAlignment="Center"/>
                    <TextBlock Text="登録" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </UniformGrid>
    </Grid>
</Window>
