<Application x:Class="AttendanceSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:AttendanceSystem"
             StartupUri="Views/MainMenuView.xaml">
    <Application.Resources>
        <!-- Windows Classic gray background -->
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F0F0F0" />

        <!-- 入力フィールドのヘッダーに使用するスタイル -->
        <Style x:Key="HeaderBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="#808080" />
            <Setter Property="BorderBrush" Value="#A0A0A0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="5,2" />
        </Style>
        
        <!-- ヘッダー内のテキスト用スタイル -->
        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- 入力用テキストボックスのスタイル：フォーカス時に背景を黄色にする -->
        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#A0A0A0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="Yellow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 単価登録のコード入力用スタイル（青背景に黄色文字） -->
        <Style x:Key="CodeInputStyle" TargetType="TextBox">
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#A0A0A0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="Background" Value="Blue" />
                    <Setter Property="Foreground" Value="Yellow" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 下部ファンクションボタン用のスタイル（グラデーション付き） -->
        <Style x:Key="FuncButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FFFFFF" Offset="0.0"/>
                        <GradientStop Color="#E6E6E6" Offset="0.4"/>
                        <GradientStop Color="#CCCCCC" Offset="0.5"/>
                        <GradientStop Color="#B3B3B3" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="#909090" BorderThickness="1" CornerRadius="2">
                            <Grid>
                                <!-- Tagプロパティから[F1]などのテキストを表示 -->
                                <TextBlock Text="{TemplateBinding Tag}" Foreground="#404040" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2,0,0" FontSize="10"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,10,0,0"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#909090"/>
                    <Setter Property="Background">
                        <Setter.Value>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F0F0F0" Offset="0.0"/>
                                <GradientStop Color="#E0E0E0" Offset="1.0"/>
                            </LinearGradientBrush>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>

