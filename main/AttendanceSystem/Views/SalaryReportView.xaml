<Window x:Class="AttendanceSystem.Views.SalaryReportView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="給与・賞与明細書" SizeToContent="WidthAndHeight" MinWidth="750" MinHeight="650"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="基本設定">
                <StackPanel Margin="15">
                    
                    <!-- 処理 -->
                    <GroupBox Header="処理" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <RadioButton Content="給与明細書" IsChecked="True" Width="170" VerticalAlignment="Center"/>
                            <RadioButton Content="賞与明細書" Width="160" VerticalAlignment="Center"/>
                            <RadioButton Content="診療従事者用 明細書" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 給与処理月 -->
                    <GroupBox Header="給与処理月" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <ComboBox SelectedIndex="0" Width="110" VerticalContentAlignment="Center" Padding="3">
                                <ComboBoxItem Content="9999年" />
                            </ComboBox>
                            <ComboBox SelectedIndex="0" Width="70" Margin="10,0,0,0" VerticalContentAlignment="Center" Padding="3">
                                <ComboBoxItem Content=" 1月" />
                                <ComboBoxItem Content=" 2月" />
                                <ComboBoxItem Content=" 3月" />
                                <ComboBoxItem Content=" 4月" />
                                <ComboBoxItem Content=" 5月" />
                                <ComboBoxItem Content=" 6月" />
                                <ComboBoxItem Content=" 7月" />
                                <ComboBoxItem Content=" 8月" />
                                <ComboBoxItem Content=" 9月" />
                                <ComboBoxItem Content="10月" />
                                <ComboBoxItem Content="11月" />
                                <ComboBoxItem Content="12月" />
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>

                    <!-- 賞与処理回 -->
                    <GroupBox Header="賞与処理回" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <ComboBox SelectedIndex="0" Width="110" VerticalContentAlignment="Center" Padding="3">
                                <ComboBoxItem Content="9999年" />
                            </ComboBox>
                            <ComboBox SelectedIndex="0" Width="70" Margin="10,0,0,0" VerticalContentAlignment="Center" Padding="3">
                                <ComboBoxItem Content="第1回" />
                                <ComboBoxItem Content="第2回" />
                                <ComboBoxItem Content="第3回" />
                                <ComboBoxItem Content="第4回" />
                                <ComboBoxItem Content="第5回" />
                                <ComboBoxItem Content="第6回" />
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>

                    <!-- 給与体系 -->
                    <GroupBox Header="給与体系" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Margin="20,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBox Text="最初" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                                <TextBlock Text="～" VerticalAlignment="Center" Margin="5,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="最後" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 社員番号 -->
                    <GroupBox Header="社員番号" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Margin="20,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBox Text="最初" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                                <TextBlock Text="～" VerticalAlignment="Center" Margin="5,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="最後" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 所属 -->
                    <GroupBox Header="所属" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Margin="20,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBox Text="最初" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                                <TextBlock Text="～" VerticalAlignment="Center" Margin="5,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="最後" Width="110" VerticalContentAlignment="Center" Padding="3"/>
                                <TextBox IsReadOnly="True" Background="#F0F0F0" BorderBrush="#ABADB3" BorderThickness="1" Width="380" Margin="5,0"/>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 差引支給額 -->
                    <GroupBox Header="差引支給額" Margin="0,0,0,0" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <CheckBox Content=" 差引支給額\0を印刷する" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </TabItem>
            <TabItem Header="プリンタ設定">
                <Grid>
                    <TextBlock Text="※プリンタ設定項目は未実装です。" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <Button Content="印刷(P)" Height="25" Margin="0,0,0,10">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="プレビュー(I)" Height="25" Margin="0,0,0,10">
                     <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
            <Button Content="キャンセル" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="Cancel_Click">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
