<Window x:Class="AttendanceSystem.Views.DayKindView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AttendanceSystem.Views"
        xmlns:vm="clr-namespace:AttendanceSystem.ViewModels"
        mc:Ignorable="d"
        Title="日種類登録" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:DayKindRegistrationViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F7" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="F10" Command="{Binding CancelCommand}" />
        <KeyBinding Key="F12" Command="{Binding RegisterCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <!-- ローカルリソースは共通スタイル(App.xaml)に移動したため削除 -->
    </Window.Resources>


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Input Area -->
        <Grid Grid.Row="1" Margin="20,20,20,20" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" />
                <RowDefinition Height="24" />
            </Grid.RowDefinitions>

            <!-- Headers -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeaderBorderStyle}">
                <TextBlock Text="コード" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HeaderBorderStyle}" Margin="-1,0,0,0">
                <TextBlock Text="名称" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource HeaderBorderStyle}" Margin="-1,0,0,0">
                <TextBlock Text="略称" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>

            <!-- Inputs -->
            <!-- UpdateSourceTrigger=LostFocus is used so OnCodeChanged triggers accurately upon enter/loss focus -->
            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding CodeText, UpdateSourceTrigger=LostFocus}" 
                     IsEnabled="{Binding IsCodeEnabled}" Style="{StaticResource InputTextBoxStyle}" Margin="0,-1,0,0" Foreground="Blue"/>
            
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" 
                     MaxLength="20" Style="{StaticResource InputTextBoxStyle}" Margin="-1,-1,0,0"/>

            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding AbbreviationText, UpdateSourceTrigger=PropertyChanged}" 
                     MaxLength="10" Style="{StaticResource InputTextBoxStyle}" Margin="-1,-1,0,0"/>

        </Grid>

        <!-- DataGrid Area -->
        <DataGrid Grid.Row="2" Margin="20,0,20,10" ItemsSource="{Binding DayKinds}" SelectedItem="{Binding SelectedDayKind}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                  HeadersVisibility="Column" SelectionMode="Single"
                  Background="White" RowBackground="White" AlternatingRowBackground="White"
                  BorderBrush="#A0A0A0" BorderThickness="1" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                  HorizontalAlignment="Left" Width="610">
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding SelectCommand}" />
            </DataGrid.InputBindings>
            <!-- Styling DataGrid Headers to match look -->
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="White" />
                    <Setter Property="BorderBrush" Value="#A0A0A0" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="4" />
                    <Setter Property="FontSize" Value="13" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="コード" Binding="{Binding FormattedCode}" Width="90"/>
                <DataGridTextColumn Header="名称" Binding="{Binding DayKindName}" Width="380"/>
                <DataGridTextColumn Header="略称" Binding="{Binding DayKindAbbreviationName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Function Key Bar -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="12" Height="45" Margin="0,5,0,0">
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F1" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F2" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F3" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F4" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F5" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F6" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F7" Content="削除" Command="{Binding DeleteCommand}" IsEnabled="{Binding IsDeleteCancelEnabled}" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F8" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F9" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F10" Content="中止" Command="{Binding CancelCommand}" IsEnabled="{Binding IsDeleteCancelEnabled}" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F11" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F12" Content="{Binding RegisterButtonText}" Command="{Binding RegisterCommand}" />
        </UniformGrid>

    </Grid>
</Window>
