<Window x:Class="AttendanceSystem.Views.JobView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AttendanceSystem.Views"
        xmlns:vm="clr-namespace:AttendanceSystem.ViewModels"
        mc:Ignorable="d"
        Title="職種登録" Height="550" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ResizeMode="NoResize"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:JobViewModel />
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F7" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="F10" Command="{Binding CancelCommand}" />
        <KeyBinding Key="F12" Command="{Binding SaveCommand}" />
    </Window.InputBindings>

    <!-- リソース定義：画面全体で使用するスタイルなど -->
    <Window.Resources>
        <!-- ローカルリソースは共通スタイル(App.xaml)に移動したため削除 -->
    </Window.Resources>


    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- (不使用) -->
            <RowDefinition Height="Auto"/> <!-- 入力エリア -->
            <RowDefinition Height="*"/>    <!-- 一覧エリア -->
            <RowDefinition Height="Auto"/> <!-- フッター（ファンクションキー） -->
        </Grid.RowDefinitions>

        <!-- 入力エリア：コード、名称、略称の入力フィールド -->
        <Grid Grid.Row="1" Margin="20,20,20,20" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>  <!-- コード用 -->
                <ColumnDefinition Width="380"/> <!-- 名称用 -->
                <ColumnDefinition Width="120"/> <!-- 略称用 -->
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="22" /> <!-- ラベル行 -->
                <RowDefinition Height="24" /> <!-- 入力行 -->
            </Grid.RowDefinitions>

            <!-- 各入力項目の見出し -->
            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource HeaderBorderStyle}">
                <TextBlock Text="コード" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource HeaderBorderStyle}" Margin="-1,0,0,0">
                <TextBlock Text="名称" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>
            <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource HeaderBorderStyle}" Margin="-1,0,0,0">
                <TextBlock Text="略称" Style="{StaticResource HeaderTextBlockStyle}" />
            </Border>

            <!-- 各入力項目のテキストボックス -->
            <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding InputCode, UpdateSourceTrigger=PropertyChanged}" 
                      IsEnabled="{Binding IsCodeEnabled}" Style="{StaticResource InputTextBoxStyle}" Margin="0,-1,0,0" Foreground="Blue"/>
            
            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding InputName, UpdateSourceTrigger=PropertyChanged}" 
                      MaxLength="20" Style="{StaticResource InputTextBoxStyle}" Margin="-1,-1,0,0"/>

            <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding InputAbbreviation, UpdateSourceTrigger=PropertyChanged}" 
                      MaxLength="6" Style="{StaticResource InputTextBoxStyle}" Margin="-1,-1,0,0"/>

        </Grid>

        <!-- 一覧表示エリア -->
        <DataGrid Grid.Row="2" Margin="20,0,20,10" ItemsSource="{Binding Jobs}" SelectedItem="{Binding SelectedJob}"
                  AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" 
                  HeadersVisibility="Column" SelectionMode="Single"
                  Background="White" RowBackground="White" AlternatingRowBackground="White"
                  BorderBrush="#A0A0A0" BorderThickness="1" GridLinesVisibility="All" HorizontalGridLinesBrush="#E0E0E0" VerticalGridLinesBrush="#E0E0E0"
                  HorizontalAlignment="Left" Width="610">
            <!-- ダブルクリックで編集開始するバインディングを追加 -->
            <DataGrid.InputBindings>
                <MouseBinding MouseAction="LeftDoubleClick" Command="{Binding DoubleClickCommand}"/>
            </DataGrid.InputBindings>
            
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="White" />
                    <Setter Property="BorderBrush" Value="#A0A0A0" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="4" />
                    <Setter Property="FontSize" Value="13" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="コード" Binding="{Binding C_JobCode}" Width="90"/>
                <DataGridTextColumn Header="名称" Binding="{Binding C_JobName}" Width="380"/>
                <DataGridTextColumn Header="略称" Binding="{Binding C_JobAbbreviationName}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- フッターエリア：ボタンスタイルと表示制御の更新 -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="12" Height="45" Margin="0,5,0,0">
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F1" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F2" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F3" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F4" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F5" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F6" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F7" Content="削除" Command="{Binding DeleteCommand}" IsEnabled="{Binding IsActionButtonsEnabled}" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F8" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F9" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F10" Content="中止" Command="{Binding CancelCommand}" IsEnabled="{Binding IsActionButtonsEnabled}" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F11" IsEnabled="False" />
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F12" Content="{Binding SaveOrCloseButtonText}" Command="{Binding SaveCommand}" />
        </UniformGrid>

    </Grid>
</Window>
