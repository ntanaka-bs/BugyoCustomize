<Window x:Class="AttendanceSystem.Views.UnitPriceView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:AttendanceSystem.ViewModels"
        mc:Ignorable="d"
        Title="単価登録" Height="580" Width="820" 
        WindowStartupLocation="CenterScreen"
        FontFamily="MS UI Gothic" FontSize="12"
        Closing="Window_Closing">
    
    <Window.DataContext>
        <viewmodels:UnitPriceViewModel />
    </Window.DataContext>

    <Window.Background>
        <!-- Windows Classic gray background -->
        <SolidColorBrush Color="#F0F0F0" />
    </Window.Background>

    <Window.Resources>
        <!-- ローカルリソースの一部は共通スタイル(App.xaml)に移動したため削除 -->
        
        <!-- Customize DataGrid cell padding and stretching to allow separator lines within cell -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="0" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Stretch" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>


    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Filter Area -->
        <Grid Grid.Row="0" Margin="10,15,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <!-- Row 1: 職種 -->
                <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Width="360" HorizontalAlignment="Left" Margin="0,0,0,2" Height="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource HeaderBorderStyle}" BorderThickness="0,0,1,0">
                            <TextBlock Text="職種" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,0"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding JobCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CodeInputStyle}" MaxLength="2"/>
                        <TextBlock Grid.Column="2" Text="{Binding JobName}" VerticalAlignment="Center" Margin="5,0"/>
                    </Grid>
                </Border>
                
                <!-- Row 2: 日種類 -->
                <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Width="360" HorizontalAlignment="Left" Margin="0,0,0,2" Height="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource HeaderBorderStyle}" BorderThickness="0,0,1,0">
                            <TextBlock Text="日種類" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,0"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding DayKindCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CodeInputStyle}" MaxLength="2"/>
                        <TextBlock Grid.Column="2" Text="{Binding DayKindName}" VerticalAlignment="Center" Margin="5,0"/>
                    </Grid>
                </Border>

                <!-- Row 3: 時間帯 -->
                <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Width="360" HorizontalAlignment="Left" Margin="0,0,0,0" Height="22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="25"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource HeaderBorderStyle}" BorderThickness="0,0,1,0">
                            <TextBlock Text="時間帯" Style="{StaticResource HeaderTextBlockStyle}" Margin="5,0"/>
                        </Border>
                        <TextBox Grid.Column="1" Text="{Binding TimeZoneCode, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource CodeInputStyle}" MaxLength="2"/>
                        <TextBlock Grid.Column="2" Text="{Binding TimeZoneName}" VerticalAlignment="Center" Margin="5,0"/>
                    </Grid>
                </Border>

            </StackPanel>

            <Button Grid.Column="2" Content="検索(S)" Width="90" Height="22" VerticalAlignment="Bottom"
                    Background="#F0F0F0" BorderBrush="#808080"
                    Command="{Binding SearchCommand}" Margin="0,0,20,0"/>
        </Grid>

        <!-- Data Grid Surface -->
        <Border Grid.Row="2" Background="White" BorderBrush="#A0A0A0" BorderThickness="1" Margin="10,0,10,10">
            <DataGrid ItemsSource="{Binding Details}" SelectedItem="{Binding SelectedDetail}" 
                      AlternatingRowBackground="#FFFFCC" RowBackground="White"
                      AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                      HeadersVisibility="Column" GridLinesVisibility="All"
                      HorizontalGridLinesBrush="#D0D0D0" VerticalGridLinesBrush="#D0D0D0"
                      RowHeaderWidth="0" BorderThickness="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F0F0" />
                        <Setter Property="BorderBrush" Value="#A0A0A0" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="日種類" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="25"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding DayKindCode}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <!-- This creates the internal column separator -->
                                    <Border Grid.Column="1" Background="#D0D0D0" VerticalAlignment="Stretch"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DayKindName}" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="時間帯" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="25"/>
                                        <ColumnDefinition Width="1"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding TimeZoneCode}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" Background="#D0D0D0" VerticalAlignment="Stretch"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TimeZoneName}" VerticalAlignment="Center" Margin="4,0"/>
                                </Grid>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn Header="単価" Binding="{Binding UnitPrice, StringFormat='¥{0:N0}'}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="0,0,4,0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="基礎時間(分)" Binding="{Binding BasicTime}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="開始時間" Binding="{Binding StartTimeString}" Width="70">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="終了時間" Binding="{Binding EndTimeString}" Width="70">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="休憩開始時間" Binding="{Binding BreakStartTimeString}" Width="95">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>

                    <DataGridTextColumn Header="休憩終了時間" Binding="{Binding BreakEndTimeString}" Width="95">
                         <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer Function Keys -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="12" Margin="10,0,10,10" Height="45">
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F1" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F2" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F3" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F4" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F5" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F6" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F7" Content="{Binding F7Text}" Command="{Binding DeleteRowCommand}"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F8" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F9" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F10" Content="{Binding F10Text}" Command="{Binding CancelCommand}"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F11" IsEnabled="False"/>
            <Button Style="{StaticResource FuncButtonStyle}" Tag="F12" Content="{Binding F12Text}" Command="{Binding F12Command}"/>
        </UniformGrid>


    </Grid>
</Window>
