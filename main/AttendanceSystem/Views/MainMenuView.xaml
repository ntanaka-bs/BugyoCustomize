<Window x:Class="AttendanceSystem.Views.MainMenuView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="勤怠管理システム - メインメニュー" Height="350" Width="300"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        Closing="Window_Closing">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="機能選択" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <Button Content="日毎勤怠チェックリスト" Width="200" Height="40" Margin="0,0,0,10" Click="OpenDailyCheckList_Click"/>
            <Button Content="マスタ管理" Width="200" Height="40" Margin="0,0,0,10" Click="OpenMasterMenu_Click"/>
        </StackPanel>
    </Grid>
</Window>
