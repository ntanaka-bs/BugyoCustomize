<Window x:Class="AttendanceSystem.Views.AttendanceRegistrationView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="勤怠データ入力" Height="500" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header part: Filter conditions and sub-grid -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Inputs on the left -->
            <StackPanel Grid.Column="0">
                <!-- 日付 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Border Background="#808080" BorderBrush="#A0A0A0" BorderThickness="1" Width="90" Height="22">
                        <TextBlock Text="日付" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    </Border>
                    <TextBox Text="2014 年 1 月 1 日" Width="150" VerticalContentAlignment="Center" Margin="5,0,10,0"/>
                    <Button Content="リスト(L)" Width="90" Height="22">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F0F0F0" Offset="0.0" />
                                <GradientStop Color="#D0D0D0" Offset="1.0" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>

                <!-- センター区分 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Border Background="#808080" BorderBrush="#A0A0A0" BorderThickness="1" Width="90" Height="22">
                        <TextBlock Text="センター区分" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    </Border>
                    <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Margin="5,0,0,0" Height="22">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="999" Width="35" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Margin="2,0,0,0"/>
                            <TextBlock Text="＠＠＠＊＠＠＠＠＊＠＠＠＊＠＠＠＊＠" VerticalAlignment="Center" Margin="5,0,5,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 日種類 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Border Background="#808080" BorderBrush="#A0A0A0" BorderThickness="1" Width="90" Height="22">
                        <TextBlock Text="日種類" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    </Border>
                    <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Margin="5,0,0,0" Height="22">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="99" Width="25" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Margin="2,0,0,0"/>
                            <TextBlock Text="＠＠＠＊＠＠＠＠＊＠＠＠＊＠＠＠＊＠" VerticalAlignment="Center" Margin="5,0,5,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 時間帯 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                    <Border Background="#808080" BorderBrush="#A0A0A0" BorderThickness="1" Width="90" Height="22">
                        <TextBlock Text="時間帯" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                    </Border>
                    <Border BorderBrush="#A0A0A0" BorderThickness="1" Background="White" Margin="5,0,0,0" Height="22">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="99" Width="25" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" Margin="2,0,0,0"/>
                            <TextBlock Text="＠＠＠＊＠＠＠＠＊＠＠＠＊＠＠＠＊＠" VerticalAlignment="Center" Margin="5,0,5,0"/>
                        </StackPanel>
                    </Border>
                    <Button Content="検索(S)" Width="90" Height="22" Margin="30,0,0,0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#F0F0F0" Offset="0.0" />
                                <GradientStop Color="#D0D0D0" Offset="1.0" />
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Sub-grid on the right -->
            <DataGrid Grid.Column="1" Width="230" Height="85" HorizontalAlignment="Right" VerticalAlignment="Top"
                      AutoGenerateColumns="False" HeadersVisibility="Column" SelectionMode="Single"
                      Background="White" RowBackground="White" AlternatingRowBackground="#E6F2E6"
                      BorderBrush="#A0A0A0" BorderThickness="1" GridLinesVisibility="None" RowHeaderWidth="0">
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F0F0F0" />
                        <Setter Property="BorderBrush" Value="#A0A0A0" />
                        <Setter Property="BorderThickness" Value="0,0,1,1" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="HorizontalContentAlignment" Value="Center" />
                    </Style>
                </DataGrid.ColumnHeaderStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="センター" Width="80" Binding="{Binding Dummy1}"/>
                    <DataGridTextColumn Header="時間帯" Width="130" Binding="{Binding Dummy2}"/>
                </DataGrid.Columns>
                <!-- dummy data for visualization -->
                <DataGrid.Items>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                </DataGrid.Items>
            </DataGrid>
        </Grid>

        <!-- Main DataGrid -->
        <DataGrid Grid.Row="1" Margin="0,0,0,10"
                  AutoGenerateColumns="False" HeadersVisibility="Column" SelectionMode="Single"
                  Background="White" RowBackground="White" AlternatingRowBackground="#FFFFCC"
                  BorderBrush="#A0A0A0" BorderThickness="1" GridLinesVisibility="All" RowHeaderWidth="0"
                  HorizontalGridLinesBrush="#D0D0D0" VerticalGridLinesBrush="#D0D0D0">
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#F0F0F0" />
                    <Setter Property="BorderBrush" Value="#A0A0A0" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="4" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="職種" Width="90" />
                <DataGridTextColumn Header="社員" Width="260" />
                <DataGridTextColumn Header="出務" Width="50" />
                <DataGridTextColumn Header="開始時間" Width="80" />
                <DataGridTextColumn Header="終了時間" Width="80" />
                <DataGridTextColumn Header="休憩開始時間" Width="90" />
                <DataGridTextColumn Header="休憩終了時間" Width="90" />
                <DataGridTextColumn Header="遅参開始時間" Width="90" />
                <DataGridTextColumn Header="遅参終了時間" Width="90" />
            </DataGrid.Columns>
            <!-- dummy data for visualization -->
            <DataGrid.Items>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
                <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">dummy</System:String>
            </DataGrid.Items>
        </DataGrid>

        <!-- Footer Buttons -->
        <UniformGrid Grid.Row="2" Rows="1" Columns="12" Height="45">
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Margin="1" Background="#E0E0E0">
                <TextBlock TextAlignment="Center" LineHeight="16">F7<LineBreak/>行削除</TextBlock>
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Margin="1" Background="#E0E0E0" Click="Close_Click">
                <TextBlock TextAlignment="Center" LineHeight="16">F10<LineBreak/>中止</TextBlock>
            </Button>
            <Button Content="" IsEnabled="False" Margin="1">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>            
            </Button>
            <Button Margin="1" Background="#E0E0E0">
                <TextBlock TextAlignment="Center" LineHeight="16">F12<LineBreak/>登録</TextBlock>
            </Button>
        </UniformGrid>
    </Grid>
</Window>
