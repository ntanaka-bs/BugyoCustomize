<Window x:Class="AttendanceSystem.Views.DailyRatOutputView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日割計算データ出力" SizeToContent="WidthAndHeight" MinWidth="650" MinHeight="450"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="基本設定">
                <StackPanel Margin="15">
                    
                    <!-- 社員番号 -->
                    <GroupBox Header="社員番号" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Width="80" VerticalContentAlignment="Center" Padding="3"/>
                            <Border BorderBrush="#C0C0C0" BorderThickness="1" Background="White" Margin="10,0,0,0" Height="22">
                                <TextBlock Text="＠＠＠＠＊＠＠＠＠＊＠＠＠＠＊＠＠＠＠＊" VerticalAlignment="Center" Margin="5,0"/>
                            </Border>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- 給与処理月 -->
                    <GroupBox Header="給与処理月" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <ComboBox Width="90" Height="22"/>
                            <ComboBox Width="60" Margin="10,0,0,0" Height="22"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 日割計算 -->
                    <GroupBox Header="日割計算" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="0.000" Width="80" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="3"/>
                            <TextBlock Text="／" VerticalAlignment="Center" Margin="15,0"/>
                            <TextBox Text="0.000" Width="80" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 端数処理 -->
                    <GroupBox Header="端数処理" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <RadioButton Content="切り上げ" IsChecked="True" Margin="0,0,80,0" VerticalAlignment="Center"/>
                            <RadioButton Content="切り捨て" Margin="0,0,80,0" VerticalAlignment="Center"/>
                            <RadioButton Content="四捨五入" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 出力先ファイル名 -->
                    <GroupBox Header="出力先ファイル名" Margin="0,0,0,0" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="15,10">
                            <TextBox Width="360" VerticalContentAlignment="Center" Padding="3"/>
                            <Button Content="参照(B)..." Width="70" Height="22" Margin="10,0,0,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <Button Content="出力開始(E)" Height="25" Margin="0,0,0,10" BorderBrush="#3399FF" BorderThickness="2" FontWeight="Bold">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#E6F2FF" Offset="0.0" />
                            <GradientStop Color="#B3D9FF" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
            
            <Button Content="キャンセル" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="Cancel_Click">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
