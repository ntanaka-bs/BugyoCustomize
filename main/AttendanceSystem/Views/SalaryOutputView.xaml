<Window x:Class="AttendanceSystem.Views.SalaryOutputView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="給与連携データ出力" SizeToContent="WidthAndHeight" MinWidth="650" MinHeight="250"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="出力設定">
                <StackPanel Margin="15">
                    
                    <TextBlock Text="処理年月" Margin="0,0,0,5" />
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,15">
                        <ComboBox Width="120" Height="22" Margin="0,0,10,0" />
                        <ComboBox Width="80" Height="22" />
                    </StackPanel>

                    <TextBlock Text="出力先ファイル名" Margin="0,0,0,5" />
                    <StackPanel Orientation="Horizontal" Margin="10,0,0,0">
                        <TextBox Width="350" Height="22" VerticalContentAlignment="Center" Margin="0,0,10,0" />
                        <Button Content="参照(B)..." Width="80" Height="22">
                            <Button.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="#F0F0F0" Offset="0.0" />
                                    <GradientStop Color="#D0D0D0" Offset="1.0" />
                                </LinearGradientBrush>
                            </Button.Background>
                        </Button>
                    </StackPanel>

                </StackPanel>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <Button Content="出力開始(E)" Height="25" Margin="0,0,0,10" IsDefault="True">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
            <Button Content="キャンセル" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="Cancel_Click">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
