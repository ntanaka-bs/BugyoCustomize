<Window x:Class="AttendanceSystem.Views.DailyAttendanceCheckListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="日毎勤怠チェックリスト" Height="550" Width="750"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="基本設定">
                <StackPanel Margin="15">
                    <!-- リスト -->
                    <GroupBox Header="リスト" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <RadioButton Content="チェックリスト" IsChecked="True" Margin="0,0,60,0" VerticalAlignment="Center"/>
                            <RadioButton Content="注意リスト" Margin="0,0,60,0" VerticalAlignment="Center"/>
                            <RadioButton Content="計算前リスト" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>
                    
                    <!-- 日付 -->
                    <GroupBox Header="日付" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="2013 年 12 月  1 日" Width="140" VerticalContentAlignment="Center" Padding="3"/>
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="20,0"/>
                            <TextBox Text="2013 年 12 月 31 日" Width="140" VerticalContentAlignment="Center" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- センター区分 -->
                    <GroupBox Header="センター区分" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="最初" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="115,0"/>
                            <TextBox Text="最後" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 職種 -->
                    <GroupBox Header="職種" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="最初" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="115,0"/>
                            <TextBox Text="最後" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 日種類 -->
                    <GroupBox Header="日種類" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="最初" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="115,0"/>
                            <TextBox Text="最後" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 時間帯 -->
                    <GroupBox Header="時間帯" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="最初" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                            <TextBlock Text="～" VerticalAlignment="Center" Margin="115,0"/>
                            <TextBox Text="最後" Width="45" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Padding="3"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 出務 -->
                    <GroupBox Header="出務" Margin="0,0,0,0" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <RadioButton Content="全て" IsChecked="True" Margin="0,0,60,0" VerticalAlignment="Center"/>
                            <RadioButton Content="有" Margin="0,0,60,0" VerticalAlignment="Center"/>
                            <RadioButton Content="無" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </TabItem>
            <TabItem Header="プリンタ設定">
                <Grid>
                    <TextBlock Text="※プリンタ設定項目は未実装です。" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <Button Content="印刷(P)" Height="25" Margin="0,0,0,10">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="プレビュー(I)" Height="25" Margin="0,0,0,10">
                     <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
            <Button Content="キャンセル" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="Cancel_Click">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
