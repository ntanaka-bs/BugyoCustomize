<Window x:Class="AttendanceSystem.Views.PaidHolidayListView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="有給一覧表" SizeToContent="WidthAndHeight" MinWidth="650" MinHeight="450"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0"
        FontFamily="MS UI Gothic" FontSize="12">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0" Margin="0,0,10,0">
            <TabItem Header="基本設定">
                <StackPanel Margin="15">
                    
                    <!-- 処理年月 -->
                    <GroupBox Header="処理年月" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <ComboBox Text="2017年" IsEditable="True" Width="80" Height="22"/>
                            <ComboBox Text="12月" IsEditable="True" Width="60" Margin="10,0,0,0" Height="22"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 計算期間 -->
                    <GroupBox Header="計算期間" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <TextBox Text="3" Width="60" VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Padding="3"/>
                            <TextBlock Text="ヶ月" VerticalAlignment="Center" Margin="5,0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 給与体系 -->
                    <GroupBox Header="給与体系" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Margin="15,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBox Text="最 初" Width="45" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="3"/>
                                <Border BorderBrush="#C0C0C0" BorderThickness="1" Background="#E8E8E8" Margin="5,0,0,0" Height="22" Width="250">
                                    <TextBlock Text="" VerticalAlignment="Center" Margin="5,0"/>
                                </Border>
                                <TextBlock Text="～" VerticalAlignment="Center" Margin="10,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="最 後" Width="45" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="3"/>
                                <Border BorderBrush="#C0C0C0" BorderThickness="1" Background="#E8E8E8" Margin="5,0,0,0" Height="22" Width="250">
                                    <TextBlock Text="" VerticalAlignment="Center" Margin="5,0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 社員番号 -->
                    <GroupBox Header="社員番号" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Margin="15,10">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                <TextBox Text="最 初" Width="45" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="3"/>
                                <Border BorderBrush="#C0C0C0" BorderThickness="1" Background="#E8E8E8" Margin="5,0,0,0" Height="22" Width="250">
                                    <TextBlock Text="" VerticalAlignment="Center" Margin="5,0"/>
                                </Border>
                                <TextBlock Text="～" VerticalAlignment="Center" Margin="10,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="最 後" Width="45" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Padding="3"/>
                                <Border BorderBrush="#C0C0C0" BorderThickness="1" Background="#E8E8E8" Margin="5,0,0,0" Height="22" Width="250">
                                    <TextBlock Text="" VerticalAlignment="Center" Margin="5,0"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </GroupBox>

                    <!-- 有給日数 -->
                    <GroupBox Header="有給日数" Margin="0,0,0,10" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="20,10">
                            <CheckBox Content="有給日数0を出力する" VerticalAlignment="Center"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 出力先ファイル名 -->
                    <GroupBox Header="出力先ファイル名" Margin="0,0,0,0" BorderBrush="#C0C0C0">
                        <StackPanel Orientation="Horizontal" Margin="15,10">
                            <TextBox Width="350" VerticalContentAlignment="Center" Padding="3"/>
                            <Button Content="参照(B)..." Width="70" Height="22" Margin="10,0,0,0">
                                <Button.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                                    </LinearGradientBrush>
                                </Button.Background>
                            </Button>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </TabItem>
            <TabItem Header="プリンタ設定">
                <Grid>
                    <TextBlock Text="※プリンタ設定項目は未実装です。" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Gray"/>
                </Grid>
            </TabItem>
        </TabControl>

        <Grid Grid.Column="1">
            <StackPanel VerticalAlignment="Top" Margin="0,20,0,0">
                <Button Content="印刷(P)" Height="25" Margin="0,0,0,10">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="プレビュー(I)" Height="25" Margin="0,0,0,10">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
                <Button Content="出力開始(E)" Height="25" Margin="0,0,0,10">
                     <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0.0" />
                            <GradientStop Color="#D0D0D0" Offset="1.0" />
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
            
            <Button Content="キャンセル" Height="25" VerticalAlignment="Bottom" Margin="0,0,0,10" Click="Cancel_Click">
                 <Button.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#F0F0F0" Offset="0.0" />
                        <GradientStop Color="#D0D0D0" Offset="1.0" />
                    </LinearGradientBrush>
                </Button.Background>
            </Button>
        </Grid>
    </Grid>
</Window>
